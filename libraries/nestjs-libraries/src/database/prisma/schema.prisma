  createdBy         String?
  modifiedBy        String?
  createdTime       DateTime?
  modifiedTime      DateTime?
  department        String?
  articleStatus     String?
  articlePermission String?
  numberOfComments  Int?
  likeCount         Int?
  unlikeCount       Int?
  attachmentCount   Int?
  suggestedCount    Int?
  lastUpVotedTime   DateTime?
  lastDownVotedTime DateTime?
  categoryName      String?
  categoryPath      String?
  embedding         Unsupported("vector")?

  @@map("solution_articles")
  @@schema("zoho")
}

