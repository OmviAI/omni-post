// ============================================================
// MERGED SCHEMA: WorldMobile + OmniPost (prism)
// 
// Rules applied:
//   - WM User model kept as base (id: String @id — Clerk-compatible)
//   - OmniPost User dropped; all its relations wired to WM User
//   - OmniPost Integration renamed → PostIntegration (@@map "prism_Integration")
//   - OmniPost OrderStatus enum renamed → PostOrderStatus
//   - OmniPost Role enum renamed → UserRole  
//   - All OmniPost models keep their @@map("prism_*") table names
//   - All WM schemas kept: public, affiliate, cdr, sendgrid, zoho
//   - OmniPost models added to "public" schema
// ============================================================

generator client {
  provider                    = "prisma-client-js"
  previewFeatures             = ["multiSchema", "postgresqlExtensions"]
  enable_experimental_decimal = "true"
  recursive_type_depth        = "-1"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, vector]
  schemas    = ["affiliate", "cdr", "public", "sendgrid", "zoho"]
}

// ============================================================
// WORLD MOBILE — USER (kept as base, Clerk-compatible)
// ============================================================

model User {
  id                    String             @id @default(uuid())
  email                 String
  password              String?
  providerName          Provider?
  name                  String?
  lastName              String?
  imageUrl              String?
  isSuperAdmin          Boolean            @default(false)
  bio                   String?
  audience              Int                @default(0)
  pictureId             String?
  providerId            String?
  timezone              Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  lastReadNotifications DateTime           @default(now())
  inviteId              String?
  activated             Boolean            @default(true)
  account               String?
  connectedAccount      Boolean            @default(false)
  lastOnline            DateTime           @default(now())
  ip                    String?
  agent                 String?
  sendSuccessEmails     Boolean            @default(true)
  sendFailureEmails     Boolean            @default(true)

  // WM relations
  messages     ChatMessage[]
  edges        FlowEdge[]
  nodes        FlowNode[]
  folders      Folder[]
  Integration  Integration[]
  projects     Project[]
  prompts      Prompt[]
  sessions     Session[]
  subfolders   Subfolder[]
  preferences  UserPreference?

  // OmniPost relations (wired to this User)
  comments        Comments[]
  itemUsers       ItemUser[]
  groupBuyer      MessagesGroup[]    @relation("groupBuyer")
  groupSeller     MessagesGroup[]    @relation("groupSeller")
  orderBuyer      Orders[]           @relation("orderBuyer")
  orderSeller     Orders[]           @relation("orderSeller")
  payoutProblems  PayoutProblems[]
  agency          SocialMediaAgency?
  organizations   UserOrganization[]
  picture         Media?             @relation("userPicture", fields: [pictureId], references: [id])

  @@unique([email, providerName])
  @@index([lastReadNotifications])
  @@index([inviteId])
  @@index([account])
  @@index([lastOnline])
  @@index([pictureId])
  @@schema("public")
}

// ============================================================
// WORLD MOBILE — CORE MODELS
// ============================================================

model Folder {
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      String
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String?     @db.Uuid
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]
  subfolders  Subfolder[]

  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model Session {
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userId      String
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folderId    String?          @db.Uuid
  projectId   String?          @db.Uuid
  subfolderId String?          @db.Uuid
  edges       FlowEdge[]
  nodes       FlowNode[]
  prompts     Prompt[]
  folder      Folder?          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subfolder   Subfolder?       @relation(fields: [subfolderId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredBy UserPreference[]
  tasks       Task[]           @relation("SessionTasks")

  @@index([folderId])
  @@index([userId])
  @@index([projectId])
  @@index([subfolderId])
  @@schema("public")
}

model Prompt {
  title       String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String        @db.Uuid
  messages    ChatMessage[]
  session     Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@schema("public")
}

model ChatMessage {
  role      String
  content   String
  timestamp DateTime @default(now())
  userId    String
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promptId  String   @db.Uuid
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([userId])
  @@schema("public")
}

model FlowNode {
  id        String   @id @default(cuid())
  nodeId    String
  type      String
  label     String
  positionX Float
  positionY Float
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  sessionId String   @db.Uuid
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, nodeId])
  @@index([sessionId])
  @@index([userId])
  @@schema("public")
}

model FlowEdge {
  id        String   @id @default(cuid())
  edgeId    String
  source    String
  target    String
  type      String?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  sessionId String   @db.Uuid
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, edgeId])
  @@index([sessionId])
  @@index([userId])
  @@schema("public")
}

model UserPreference {
  userId             String   @id
  onboardingGAITSeen Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  currentSessionId   String?  @db.Uuid
  currentSession     Session? @relation(fields: [currentSessionId], references: [id])
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentSessionId])
  @@schema("public")
}

model DataDocument {
  id        BigInt                 @id @default(autoincrement())
  text      String                 @db.VarChar
  metadata_ Json?
  node_id   String?                @db.VarChar
  embedding Unsupported("vector")?
  category  String?                @db.VarChar
  flagged   Boolean                @default(false)
  lock      Boolean                @default(false)
  priority  String?                @db.VarChar
  reason    String?                @db.VarChar
  source    String?                @db.VarChar
  tags      String[]

  @@map("data_documents")
  @@schema("public")
}

model Project {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  folders     Folder[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]

  @@index([userId])
  @@schema("public")
}

model Subfolder {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  folderId    String    @db.Uuid
  sessions    Session[]
  folder      Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([userId])
  @@schema("public")
}

// WM Integration (OAuth — Google/Microsoft)
model Integration {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String
  provider     IntegrationProvider
  service      IntegrationService
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?           @db.Timestamptz(6)
  scope        String?
  tokenType    String?
  metadata     Json?
  createdAt    DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime            @db.Timestamptz(6)
  User         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, service], map: "integration_user_provider_service_unique")
  @@index([userId])
  @@schema("public")
}

model ItemType {
  id   Int    @id
  name String @unique

  @@schema("public")
}

model DailyScanPoints {
  date          DateTime
  did           String
  locations     Json?
  cells         Int?
  scans         Int?
  points        Int?
  user_did_link user_did_link @relation(fields: [did], references: [did])

  @@id([date, did])
  @@map("daily_scan_points")
  @@schema("public")
}

model user_did_link {
  id                String            @id
  user_id           String?           @db.VarChar(255)
  did               String            @unique
  is_linked         Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime
  daily_scan_points DailyScanPoints[]

  @@schema("public")
}

model opan_users {
  id       String  @id @db.VarChar(255)
  clerk_id String? @db.VarChar(255)
  opan_id  String? @unique @db.Uuid

  name     String? @db.VarChar(255)
  email    String? @unique @db.Citext
  username String? @db.Citext

  role             String?  @db.VarChar(255)
  is_partner       Boolean?
  email_verified   Boolean?
  image            String?  @db.VarChar(255)
  display_username String?  @db.VarChar(255)
  billing_address  String?  @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  opan_created_at                  DateTime? @db.Timestamptz(6)
  last_logged_in                   DateTime? @db.Timestamptz(6)
  affiliate_code                   String?
  passkey_registered               Boolean   @default(false)
  wallet_registered                Boolean   @default(false)
  has_staked                       Boolean   @default(false)
  payout_balance                   String?
  completed_orders_count           Int       @default(0)
  completed_orders_total_value     String?
  wmtx_eligible_orders_count       Int       @default(0)
  wmtx_eligible_orders_total_value String?
  staking_total_staked             String?

  opan_orders            opan_orders[] @relation("OpanOrdersByInternalUser")
  opan_orders_by_opan_id opan_orders[] @relation("OpanOrdersByOpanUser")

  opan_subscriptions            opan_subscriptions[] @relation("OpanSubsByInternalUser")
  opan_subscriptions_by_opan_id opan_subscriptions[] @relation("OpanSubsByOpanUser")

  opan_payments            opan_payments[] @relation("OpanPaymentsByInternalUser")
  opan_payments_by_opan_id opan_payments[] @relation("OpanPaymentsByOpanUser")

  accounts                           accounts[]
  opan_admin_actions                 opan_admin_actions[]
  host_locations                     host_locations[]
  opan_operations                    opan_operations[]             @relation("OpanUserOperations")
  tasks                              Task[]
  threads_threads_host_idTousers     threads[]                     @relation("threads_host_idTousers")
  threads_threads_operator_idTousers threads[]                     @relation("threads_operator_idTousers")
  opan_user_linked_affiliates        opan_user_linked_affiliates[]
  businessPlanChunks                 BusinessPlanChunk[]
  businessPlan                       BusinessPlanSubmission?
  opan_staking_transactions          opan_staking_transactions[]

  @@index([username, display_username], map: "idx_opan_users_username_search")
  @@map("opan_users")
  @@schema("public")
}

model opan_orders {
  id            String  @id
  opan_order_id String? @unique @db.VarChar(255)

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? @db.Timestamp(6)

  payment_type  String
  payment_db_id String @db.Uuid
  user_id       String @db.VarChar(255)
  opan_user_id  String? @db.Uuid

  status                    OrderStatus
  coupon_code               String?
  affiliate_id              String?
  affiliate_discount_amount Int         @default(0)
  family_discount_amount    Int         @default(0)
  wm_coupon_code            String?
  wm_coupon_discount_amount Int         @default(0)
  tier_staking_percent      Float       @default(0)
  tier_staking_discount     Int         @default(0)
  whitelist_code            String?

  opan_expired_items   opan_expired_items[]
  opan_items           opan_items[]
  opan_payment         opan_payments        @relation(fields: [payment_db_id], references: [id])
  opan_user            opan_users           @relation("OpanOrdersByInternalUser", fields: [user_id], references: [id])
  opan_user_by_opan_id opan_users?          @relation("OpanOrdersByOpanUser", fields: [opan_user_id], references: [opan_id])
  opan_order_meta      opan_order_meta?     @relation("OpanOrderToMeta")

  @@index([deleted_at])
  @@index([user_id], map: "idx_opan_orders_user_id")
  @@index([payment_db_id], map: "idx_opan_orders_payment_id")
  @@index([opan_user_id], map: "idx_opan_orders_opan_user_id")
  @@map("opan_orders")
  @@schema("public")
}

model opan_items {
  id           String  @id
  opan_item_id String? @unique

  created_at   DateTime?
  updated_at   DateTime?
  deleted_at   DateTime?
  product_type String?
  product_id   String?
  order_id     String?
  reservation_id  Int?
  price           Int?
  metadata        String?
  parsed_metadata Json?

  opan_expired_items opan_expired_items[]
  opan_order         opan_orders?         @relation(fields: [order_id], references: [id])

  @@index([deleted_at])
  @@index([order_id], map: "idx_opan_items_order_id")
  @@map("opan_items")
  @@schema("public")
}

model opan_expired_items {
  id                   Int     @id @default(autoincrement())
  opan_expired_item_id String? @unique

  product_type    String?
  order_id        String?
  item_id         String?
  price           Int?
  metadata        String?
  parsed_metadata Json?

  opan_item  opan_items?  @relation(fields: [item_id], references: [id])
  opan_order opan_orders? @relation(fields: [order_id], references: [id])

  @@index([order_id], map: "idx_opan_expired_items_order_id")
  @@map("opan_expired_items")
  @@schema("public")
}

model opan_payments {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opan_payment_id String? @unique

  provider    String? @db.VarChar(255)
  provider_id String? @db.VarChar(255)
  address_id  String? @db.Uuid
  currency    String? @db.VarChar(255)
  total       BigInt?
  paid        BigInt?

  user_id      String? @db.VarChar(255)
  opan_user_id String? @db.Uuid

  is_expired                        Boolean?
  bank_transfer_url                 String?
  bank_transfer_payment_intent_id   String?
  bank_transfer_checkout_session_id String?
  jira_order_id                     String?
  freshdesk_id                      String?
  node_ids                          String?

  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  bank_payment_url String?
  payment_status   String?
  payment_url      String?

  opan_orders          opan_orders[]
  airnode_inventory    airnode_inventory[]
  opan_addresses       opan_addresses?     @relation(fields: [address_id], references: [id], onUpdate: NoAction)
  opan_user            opan_users?         @relation("OpanPaymentsByInternalUser", fields: [user_id], references: [id], onUpdate: NoAction)
  opan_user_by_opan_id opan_users?         @relation("OpanPaymentsByOpanUser", fields: [opan_user_id], references: [opan_id])

  @@index([created_at], map: "idx_opan_payments_created_at")
  @@index([provider, provider_id], map: "idx_opan_payments_provider")
  @@index([user_id], map: "idx_opan_payments_user")
  @@index([opan_user_id], map: "idx_opan_payments_opan_user")
  @@map("opan_payments")
  @@schema("public")
}

model opan_subscriptions {
  id                   String  @id
  opan_subscription_id String? @unique

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  user_id      String  @db.VarChar(255)
  opan_user_id String? @db.Uuid

  affiliate_id                  String?  @db.Uuid
  current_period_start          DateTime @db.Timestamptz(6)
  current_period_end            DateTime @db.Timestamptz(6)
  status                        String
  last_payment_id               Int?
  last_payment_amount           Int?
  product_id                    String?
  product                       Int?
  product_key                   String?
  item_id                       String?
  sub_period                    String
  first_payment_discounted      Boolean? @default(false)
  first_payment_discount_amount Int?     @default(0)
  original_undiscounted_amount  Int?
  affiliate_discount_amount     Int?
  family_discount_amount        Int?     @default(0)
  payment_provider              String?
  provider_sub_id               String?
  recurring_discount            Boolean?
  package_type                  String?
  details                       Json?

  affiliateUser        opan_affiliate_users? @relation(fields: [affiliate_id], references: [id])
  opan_user            opan_users            @relation("OpanSubsByInternalUser", fields: [user_id], references: [id], onDelete: Cascade)
  opan_user_by_opan_id opan_users?           @relation("OpanSubsByOpanUser", fields: [opan_user_id], references: [opan_id])

  @@index([affiliate_id])
  @@index([deleted_at])
  @@index([product_id])
  @@index([user_id])
  @@index([opan_user_id])
  @@map("opan_subscriptions")
  @@schema("public")
}

model opan_staking_transactions {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opan_staking_tx_id String @unique @db.Uuid

  transaction_id     String?
  contract_address   String?
  wallet_address     String?
  stake_tier         Int?
  type               String?
  amount             String?
  transaction_amount String?
  created_at         DateTime? @db.Timestamptz(6)
  updated_at         DateTime? @db.Timestamptz(6)

  opan_user_id String     @db.Uuid
  opan_user    opan_users @relation(fields: [opan_user_id], references: [opan_id], onDelete: Cascade)

  @@index([opan_user_id])
  @@map("opan_staking_transactions")
  @@schema("public")
}

model opan_order_meta {
  order_db_id   String @id
  reservation   Json?
  wmtx_reward   Json?
  checkout_info Json?
  opan_order    opan_orders @relation("OpanOrderToMeta", fields: [order_db_id], references: [id])

  @@map("opan_order_meta")
  @@schema("public")
}

model accounts {
  id                       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                     String?    @db.VarChar(255)
  provider                 String?    @db.VarChar(255)
  provider_account_id      String?    @db.VarChar(255)
  refresh_token            String?    @db.VarChar(255)
  access_token             String?    @db.VarChar(255)
  expires_at               BigInt?
  token_type               String?    @db.VarChar(255)
  scope                    String?    @db.VarChar(255)
  id_token                 String?
  session_state            String?    @db.VarChar(255)
  user_id                  String?    @db.VarChar(255)
  access_token_expires_at  DateTime?  @db.Timestamptz(6)
  refresh_token_expires_at DateTime?  @db.Timestamptz(6)
  password                 String?    @db.VarChar(255)
  created_at               DateTime   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime   @default(now()) @db.Timestamptz(6)
  opan_user                opan_users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_accounts_user")
  @@map("accounts")
  @@schema("public")
}

model opan_addresses {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  host_locations host_locations[]
  opan_payments  opan_payments[]

  @@map("opan_addresses")
  @@schema("public")
}

model opan_admin_actions {
  id            BigInt      @id @default(autoincrement())
  admin_id      String?     @db.VarChar(255)
  user_id       String?     @db.VarChar(255)
  user_email    String?     @db.VarChar(254)
  action_status String?     @db.VarChar(20)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  opan_user     opan_users? @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_opan_admin_actions_created_at")
  @@index([user_id], map: "idx_opan_admin_actions_user")
  @@map("opan_admin_actions")
  @@schema("public")
}

model opan_operations {
  h3_id      String
  user_id    String   @db.VarChar(255)
  status     String?  @db.VarChar(64)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  hexes      hexes    @relation(fields: [h3_id], references: [h3_id], onDelete: Cascade, onUpdate: NoAction)
  opan_user  opan_users @relation("OpanUserOperations", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([h3_id, user_id])
  @@map("opan_operations")
  @@schema("public")
}

model Task {
  id            Int           @id @default(autoincrement())
  user_id       String        @db.VarChar(255)
  title         String?
  description   String?
  status        TaskStatus
  priority      TaskPriority?
  due_at        DateTime?     @db.Timestamptz(6)
  completed_at  DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  sessionId     String?       @db.Uuid
  current_stage String?       @db.VarChar(50)
  latest_output Json?
  session       Session?      @relation("SessionTasks", fields: [sessionId], references: [id], onDelete: Cascade)
  opan_user     opan_users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([due_at], map: "idx_tasks_due")
  @@index([user_id, status, due_at], map: "idx_tasks_user_status_due")
  @@index([sessionId, status, due_at], map: "idx_tasks_session_status_due")
  @@index([user_id], map: "idx_tasks_user_id")
  @@index([sessionId], map: "idx_tasks_session_id")
  @@map("tasks")
  @@schema("public")
}

model airnode_inventory {
  id                           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uuid                         String?    @db.VarChar(255)
  model                        String?    @db.VarChar(255)
  payment_id                   String?    @db.Uuid
  is_reserved                  Boolean?
  status_deposit_paid          DateTime?  @db.Timestamptz(6)
  status_purchased             DateTime?  @db.Timestamptz(6)
  status_shipped               DateTime?  @db.Timestamptz(6)
  status_delivered             DateTime?  @db.Timestamptz(6)
